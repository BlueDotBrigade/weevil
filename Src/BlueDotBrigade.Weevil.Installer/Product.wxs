<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
	xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx"
	xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
	
	<Package Name="Weevil" Language="1033" Version="$(var.WeevilVersion)" Manufacturer="Blue Dot Brigade" UpgradeCode="ee20260f-f191-4bfc-9c60-242a12e40079" InstallerVersion="200">
		<SummaryInformation Manufacturer="Blue Dot Brigade" Description="Weevil" />

		<Property Id="ARPPRODUCTICON" Value="Weevil.ico" />
		<Property Id="ARPHELPLINK" Value="http://Weevil.BlueDotBrigade.com" />
		<Property Id="ARPCONTACT" Value="Blue Dot Brigade" />
		<Property Id="ARPURLINFOABOUT" Value="http://Weevil.BlueDotBrigade.com" />
		<Property Id="WEEVIL_COLLECT_ANONYMOUS_METRICS" Value="1" />
		<WixVariable Id="WixUILicenseRtf" Value="$(var.InstallerLicenseRtfPath)" />
		<ui:WixUI Id="WixUI_InstallDir_TelemetryDlg" InstallDirectory="INSTALLFOLDER" />

		<!-- Check installed .NET Core Runtime on the target computer. -->
		<netfx:DotNetCompatibilityCheck Id="netCoreStatus"
										Property="NETCORESTATUS" RollForward="latestMajor"
										RuntimeType="desktop" Version="9.0.0" Platform="x64" />
		<Launch Condition="Installed OR NETCORESTATUS=&quot;0&quot;"
				Message="[ProductName] requires Microsoft .NET Core 9.0 runtime (or later) to be installed.  [\[]Desktop, x64[\]]" />

		<MajorUpgrade DowngradeErrorMessage="A newer version of Weevil is already installed." />
		<MediaTemplate EmbedCab="yes" />

		<Feature Id="ProductFeature" Title="Weevil" Level="1">
			<ComponentGroupRef Id="generated_weevil_bin_files" />
			<ComponentGroupRef Id="generated_documentation_doc_files" />
			<ComponentGroupRef Id="generated_documentation_license_files" />
			
			<ComponentRef Id="WeevilShortcut" />
			<ComponentRef Id="ScriptsPathComponent" />
			<ComponentRef Id="WeevilLogFileAssociation" />
			<ComponentGroupRef Id="RegistryKeys" />
		</Feature>
	</Package>

	<Fragment>
			<StandardDirectory Id="ProgramMenuFolder">
				<Directory Id="BlueDotBrigadeShortcutDir" Name="Blue Dot Brigade">
					<Directory Id="WeevilShortcutDir" Name="Weevil" />
				</Directory>
			</StandardDirectory>
			<StandardDirectory Id="ProgramFiles64Folder">
				<Directory Id="BlueDotBrigade" Name="BlueDotBrigade">
					<Directory Id="INSTALLFOLDER" Name="Weevil">
							<Directory Id="InstallFolderBin" Name="Bin" />
							<Directory Id="LicenseDir" Name="Licenses" />
							<Directory Id="DocDir" Name="Doc" />
						</Directory>
				</Directory>
			</StandardDirectory>
		</Fragment>
	<Fragment>
		<!--
			HKCU = HKEY_CURRENT_USER
			HKLM = HKEY_LOCAL_MACHINE
		-->
		<ComponentGroup Id="RegistryKeys" Directory="INSTALLFOLDER">
			<Component Id="RegistryComponent" Guid="BDB8AD0C-3284-4C23-8FFA-A41F7831F83E">
				<RegistryKey Root="HKCU" Key="Software\BlueDotBrigade\Weevil">
					<RegistryValue Type="string" Name="EnableBetaFeatures" Value="True" />
				</RegistryKey>
				<Environment Id="WeevilTelemetrySourceEnvironmentVariable"
					Name="WEEVIL_TELEMETRY_SOURCE"
					Value="Production"
					Action="set"
					Part="all"
					System="yes" />
			</Component>
			<Component Id="TelemetryUsernameEnabledComponent" Guid="1D8C66F0-8E03-4F06-B575-58254B6F35BE" Condition="WEEVIL_COLLECT_ANONYMOUS_METRICS = &quot;1&quot;">
				<Environment Id="WeevilTelemetryUsernameEnabledEnvironmentVariable"
					Name="WEEVIL_TELEMETRY_USERNAME"
					Value="weevil_telemetry_producer"
					Action="set"
					Part="all"
					System="yes" />
				<!--
					An empty string will result in a compiler error.
					WIX0006 : The Environment/@Value attribute's value cannot be an empty string. If a value is not required, simply remove the entire attribute.
				-->
				<Environment Id="WeevilTelemetrySecretEnabledEnvironmentVariable"
					Name="WEEVIL_TELEMETRY_SECRET"
					Value="NOT_SET"
					Action="set"
					Part="all"
					System="yes" />
			</Component>
			<Component Id="TelemetryUsernameDisabledComponent" Guid="8AFBB0A6-E049-4D07-91FB-E38A90CA7E92" Condition="WEEVIL_COLLECT_ANONYMOUS_METRICS &lt;&gt; &quot;1&quot;">
				<Environment Id="WeevilTelemetryUsernameDisabledEnvironmentVariable"
					Name="WEEVIL_TELEMETRY_USERNAME"
					Action="remove"
					Part="all"
					System="yes" />
				<Environment Id="WeevilTelemetrySecretDisabledEnvironmentVariable"
					Name="WEEVIL_TELEMETRY_SECRET"
					Action="remove"
					Part="all"
					System="yes" />
			</Component>
		</ComponentGroup>
	</Fragment>
	<Fragment>
		<DirectoryRef Id="INSTALLFOLDER">
			<Component Id="WeevilLogFileAssociation" Guid="84FACF5A-7EF5-4285-84B6-FC96F4A08177">
				<RegistryKey Root="HKLM" Key="Software\RegisteredApplications">
					<RegistryValue Name="Weevil" Type="string" Value="Software\BlueDotBrigade\Weevil\Capabilities" KeyPath="yes" />
				</RegistryKey>

				<RegistryKey Root="HKLM" Key="Software\BlueDotBrigade\Weevil\Capabilities">
					<RegistryValue Name="ApplicationName" Type="string" Value="Weevil" />
					<RegistryValue Name="ApplicationDescription" Type="string" Value="View and analyze log files using Weevil." />
					<RegistryKey Key="FileAssociations">
						<RegistryValue Name=".log" Type="string" Value="BlueDotBrigade.Weevil.LogFile" />
					</RegistryKey>
				</RegistryKey>

				<RegistryKey Root="HKLM" Key="Software\Classes\BlueDotBrigade.Weevil.LogFile">
					<RegistryValue Type="string" Value="Log File" />
					<RegistryValue Name="FriendlyTypeName" Type="string" Value="Log File" />
					<RegistryKey Key="DefaultIcon">
						<RegistryValue Type="string" Value="&quot;[InstallFolderBin]WeevilGui.exe&quot;,0" />
					</RegistryKey>
					<RegistryKey Key="shell">
						<RegistryValue Type="string" Value="open" />
						<RegistryKey Key="open">
							<RegistryKey Key="command">
								<RegistryValue Type="string" Value="&quot;[InstallFolderBin]WeevilGui.exe&quot; &quot;%1&quot;" />
							</RegistryKey>
						</RegistryKey>
					</RegistryKey>
				</RegistryKey>

				<RegistryKey Root="HKLM" Key="Software\Classes\.log\OpenWithProgids">
					<RegistryValue Name="BlueDotBrigade.Weevil.LogFile" Type="string" Value="" />
				</RegistryKey>

				<RegistryKey Root="HKLM" Key="Software\Classes\Applications\WeevilGui.exe">
					<RegistryValue Name="FriendlyAppName" Type="string" Value="Weevil" />
					<RegistryKey Key="SupportedTypes">
						<RegistryValue Name=".log" Type="string" Value="" />
					</RegistryKey>
					<RegistryKey Key="shell\open\command">
						<RegistryValue Type="string" Value="&quot;[InstallFolderBin]WeevilGui.exe&quot; &quot;%1&quot;" />
					</RegistryKey>
				</RegistryKey>
			</Component>
		</DirectoryRef>
	</Fragment>
	<Fragment>
		<UI>
			<Dialog Id="TelemetryDialog" Width="370" Height="270" Title="[ProductName] Setup">
				<Control Id="Title" Type="Text" X="15" Y="6" Width="340" Height="15" Transparent="yes" NoPrefix="yes" Text="{\WixUI_Font_Title}Telemetry" />
				<Control Id="Description" Type="Text" X="20" Y="23" Width="330" Height="30" Transparent="yes" NoPrefix="yes" Text="Knowing how the application is being used helps to improve the user experience.&#xD;&#xA;For example: How often is the dashboard opened?" />
				<Control Id="TelemetryOptInCheckbox" Type="CheckBox" X="20" Y="90" Width="330" Height="17" Property="WEEVIL_COLLECT_ANONYMOUS_METRICS" CheckBoxValue="1" Text="Collect anonymous metrics?" />
				<Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
				<Control Id="TelemetryExplanation" Type="Text" X="20" Y="202" Width="330" Height="30" Transparent="yes" NoPrefix="yes" Text="No personal or proprientary information will be collected (e.g. filters, filenames, etc.)." />
				<Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="!(loc.WixUIBack)" />
				<Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="!(loc.WixUINext)" />
				<Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="!(loc.WixUICancel)" />
			</Dialog>
		</UI>
	</Fragment>
	<Fragment>
		<DirectoryRef Id="WeevilShortcutDir">
			<!-- Hotkey: 87 (W) + 512 (Ctrl) + 1024 (Alt) = 1623 -->
			<Component Id="WeevilShortcut" Guid="BDBCC900-E933-4FF7-8E2C-B167BD12891D">
				<Shortcut Id="GuiShortcut" Name="Weevil GUI" Description="Weevil log view application." Target="[InstallFolderBin]\WeevilGui.exe" WorkingDirectory="InstallFolderBin" Hotkey="1623" />
				<Shortcut Id="CliShortcut" Name="Weevil CLI" Description="Weevil command-line application." Target="[SystemFolder]cmd.exe" Arguments='/k "[InstallFolderBin]\WeevilCli.exe"' WorkingDirectory="InstallFolderBin" />
				<!-- 
				The KeyPath attribute is set to yes, which means that this registry key 
				is the key path for the component. The Windows Installer uses the key path 
				to check if a component is already installed on the system. If the key path exists, 
				it is assumed that the component is installed.
				-->
				<RegistryValue Root="HKCU" Key="Software\BlueDotBrigade\Weevil" Name="installed" Type="integer" Value="1" KeyPath="yes" />
				<RemoveFolder Id="WeevilShortcutDir_Remove" Directory="WeevilShortcutDir" On="uninstall" />
				<RemoveFolder Id="BlueDotBrigadeShortcutDir_Remove" Directory="BlueDotBrigadeShortcutDir" On="uninstall" />
			</Component>
		</DirectoryRef>
	</Fragment>
</Wix>
